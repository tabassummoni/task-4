# Example environment variables for the server
## Example using provided credentials (replace host if using remote server)
# username: test4, password: tast4
MONGO_URI=mongodb://test4:tast4@127.0.0.1:27017/user_management_system
PORT=5001
JWT_SECRET=replace_this_with_a_strong_secret
APP_URL=http://localhost:5001
CORS_ORIGIN=*
